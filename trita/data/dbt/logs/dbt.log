  create  table "postgres"."gold"."fact_order_line__dbt_tmp"
  
  
    as
  
  (
    -- Order line grain (minimal path for VA-05)
select
    l.tenant_id,
    l.order_id,
    l.line_item_id,
    l.variant_id,
    l.sku,
    l.quantity,
    l.line_price,
    l.order_updated_at,
