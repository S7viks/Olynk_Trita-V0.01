  create view "postgres"."quarantine"."shopify_invalid__dbt_tmp"
    
    
  as (
    -- Rows failing staging DQ (T-P0-022 shell)
select
    'order_line_missing_variant' as failure_reason,
    l.tenant_id,
    l.order_id,
    l.line_item_id,
