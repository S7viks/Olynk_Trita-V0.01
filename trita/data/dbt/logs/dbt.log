  create view "postgres"."staging"."stg_shopify_order_lines__dbt_tmp"
    
    
  as (
    -- Exploded order line items for gold.fact_order_line
select
    o.tenant_id,
    o.order_id,
    o.order_name,
    o.order_updated_at,
    o.ingested_at,
    (li ->> 'id')::text as line_item_id,
    (li ->> 'variant_id')::text as variant_id,
    li ->> 'sku' as sku,
    (li ->> 'quantity')::numeric as quantity,
    (li ->> 'price')::numeric as line_price
from "postgres"."staging"."stg_shopify_orders" as o
cross join lateral jsonb_array_elements(
    case
        when jsonb_typeof(o.line_items) = 'array' then o.line_items
        else '[]'::jsonb
    end
) as li
  );
[0m01:36:54.549993 [debug] [Thread-3 (]: SQL status: BEGIN in 0.529 seconds
[0m01:36:54.550360 [debug] [Thread-3 (]: Using postgres connection "model.trita.fact_inventory_daily"
[0m01:36:54.550739 [debug] [Thread-3 (]: On model.trita.fact_inventory_daily: /* {"app": "dbt", "dbt_version": "1.8.2", "profile_name": "trita", "target_name": "dev", "node_id": "model.trita.fact_inventory_daily"} */

  
    

  create  table "postgres"."gold"."fact_inventory_daily__dbt_tmp"
  
  
    as
  
  (
    -- SKU × day inventory shell from Shopify inventory levels
select
    i.tenant_id,
    i.inventory_item_id,
    coalesce(i.level_updated_at::date, i.ingested_at::date) as inventory_date,
    i.available_qty as on_hand,
    i.ingested_at,
    md5(
        i.tenant_id::text || '|' || i.inventory_item_id || '|'
        || coalesce(i.level_updated_at::date, i.ingested_at::date)::text
    ) as inventory_daily_key
from "postgres"."staging"."stg_shopify_inventory" as i
where i.available_qty is not null
  and i.available_qty >= 0
  );
  
