    p.product_id,
    p.product_title,
    (v ->> 'id')::text as variant_id,
    v ->> 'sku' as sku,
    v ->> 'title' as variant_title,
    (v ->> 'inventory_quantity')::numeric as inventory_quantity,
    p.ingested_at
from "postgres"."staging"."stg_shopify_products" as p
