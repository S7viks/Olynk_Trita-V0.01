  create  table "postgres"."gold"."sku_unit_cost__dbt_tmp"
  
  
    as
  
  (
    -- Latest unit cost per tenant × sku from CSV hub (Tally path)
select distinct on (tenant_id, sku)
    tenant_id,
    sku as sku_code,
    unit_cost,
    as_of,
    source,
