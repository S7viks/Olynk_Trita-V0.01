  as (
    select
    e.tenant_id,
    e.external_id as settlement_id,
    e.payload ->> 'entity_id' as payment_id,
    coalesce((e.payload ->> 'amount')::bigint, 0) as amount_paise,
    e.payload ->> 'currency' as currency,
