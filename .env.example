# Trita V0.0.1 — environment template (no secrets)
# Copy:  cp .env.example .env
# Never commit .env, .env.local, or real keys. See infra/supabase/PROJECT.md for project ref.

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Auth → Providers → Google: enable; redirect URL:
#   http://localhost:3000/auth/callback  (and production app URL)
# Auth → URL Configuration: Site URL = NEXT_PUBLIC_WEB_URL; add /auth/callback to redirect allow list
# Auth → Providers → Email: disable "Confirm email" for immediate signup → onboarding (Trita default)
# Web local: copy Supabase vars into trita/apps/web/.env.local
# Optional local pilot button (never set in production): NEXT_PUBLIC_TRITA_DEV_LOGIN=true
# Legacy name (same value as publishable key if your dashboard still labels it "anon"):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Legacy JWT secret (Dashboard → API → JWT Settings). NOT sb_secret_* API keys.
# For signing Trita API tokens only; user tokens verified via Supabase Auth when URL is set.
TRITA_JWT_SECRET=
SUPABASE_JWT_SECRET=
SUPABASE_URL=

# --- API (local default — no Render/Fly card required) ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
API_JWT_SECRET=
ENVIRONMENT=development
# Local: same as API URL. Cloud: https://your-api.onrender.com (after Blueprint apply)
RENDER_HEALTH_URL=http://127.0.0.1:8000

# --- Postgres (Dashboard → Database → Connection string) ---
# Pooler (app runtime): postgresql://postgres.YOUR_PROJECT_REF:[PASSWORD]@<region>.pooler.supabase.com:6543/postgres
# Direct (DDL/SQL editor): postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=

# --- dbt (optional — scripts/run_dbt.py reads DATABASE_URL; override only if needed) ---
# DBT_HOST=
# DBT_PORT=6543
# DBT_USER=
# DBT_PASSWORD=
# DBT_DATABASE=postgres

# --- LiteLLM (Phase 0+) ---
LITELLM_PROXY_URL=http://127.0.0.1:4000
LITELLM_MASTER_KEY=
LITELLM_TENANT_TOKEN_BUDGET=5000
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Shopify OAuth (Partner *mock/dev* app — your dev store, not Yoga Bar's live shop) ---
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Must match Shopify Partner app → Allowed redirection URL(s)
SHOPIFY_OAUTH_REDIRECT_URI=http://localhost:3000/api/sources/shopify/callback
SHOPIFY_REDIRECT_URI=http://localhost:3000/api/sources/shopify/callback
SHOPIFY_SCOPES=read_orders,read_inventory,read_products
SHOPIFY_WEBHOOK_SECRET=
# Default dev store when connect URL has no ?shop= (API scripts / legacy)
SHOPIFY_DEV_SHOP_DOMAIN=tritabyolynk.myshopify.com
# Legacy alias — same as SHOPIFY_DEV_SHOP_DOMAIN
YOGA_BAR_SHOP_DOMAIN=tritabyolynk.myshopify.com
# Trita *tenant* UUID for pilot (public.tenants slug yoga-bar) — used for JWT dev login + Dagster, NOT Shopify
YOGA_BAR_TENANT_ID=
# Fernet key for connector tokens; defaults to SUPABASE_JWT_SECRET if unset.
CONNECTOR_TOKEN_KEY=

# --- Web (OAuth success redirect + connect from /sources) ---
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# Optional: dev store handle shown on Sources connect form (defaults tritabyolynk)
# NEXT_PUBLIC_SHOPIFY_DEV_SHOP=tritabyolynk

# --- Pilot / dev helpers (optional) ---
# TRITA_API_PORT=8000
# TRITA_RUN_ISOLATION=1
# TRITA_RUN_VA05=1
# TRITA_RUN_VA09=1
# TRITA_ORCH_INGEST_MODE=direct

# --- Email / Slack (Phase 3+) ---
RESEND_API_KEY=
SLACK_WEBHOOK_URL=

# --- Billing (Phase 5) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
