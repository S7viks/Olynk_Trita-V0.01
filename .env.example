# Trita V0.0.1 — environment template (no secrets)
# Copy:  cp .env.example .env
# Never commit .env, .env.local, or real keys. See infra/supabase/PROJECT.md for project ref.

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy name (same value as publishable key if your dashboard still labels it "anon"):
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- API (FastAPI local / Render) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
API_JWT_SECRET=
# Must match SUPABASE_JWT_SECRET for HS256 JWT verification (do not use publishable key here).
ENVIRONMENT=development
RENDER_HEALTH_URL=

# --- Postgres (Dashboard → Database → Connection string) ---
# Pooler (app runtime): postgresql://postgres.YOUR_PROJECT_REF:[PASSWORD]@<region>.pooler.supabase.com:6543/postgres
# Direct (DDL/SQL editor): postgresql://postgres:[PASSWORD]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=

# --- dbt (optional — scripts/run_dbt.py reads DATABASE_URL; override only if needed) ---
# DBT_HOST=
# DBT_PORT=6543
# DBT_USER=
# DBT_PASSWORD=
# DBT_DATABASE=postgres

# --- LiteLLM (Phase 0+) ---
LITELLM_PROXY_URL=http://127.0.0.1:4000
LITELLM_MASTER_KEY=
LITELLM_TENANT_TOKEN_BUDGET=5000
GEMINI_API_KEY=
GROQ_API_KEY=

# --- OpenMeter (Phase 0+) ---
OPENMETER_API_KEY=
OPENMETER_URL=

# --- Shopify OAuth (tritabyolynk dev shop) ---
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_OAUTH_REDIRECT_URI=http://localhost:8000/v1/sources/shopify/callback
SHOPIFY_REDIRECT_URI=http://localhost:8000/v1/sources/shopify/callback
SHOPIFY_SCOPES=read_orders,read_inventory,read_products
SHOPIFY_WEBHOOK_SECRET=
YOGA_BAR_SHOP_DOMAIN=tritabyolynk.myshopify.com
# After seed migration: select id from public.tenants where slug = 'yoga-bar';
YOGA_BAR_TENANT_ID=
# Fernet key for connector tokens; defaults to SUPABASE_JWT_SECRET if unset.
CONNECTOR_TOKEN_KEY=

# --- Web (OAuth success redirect in production) ---
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# --- Pilot / dev helpers (optional) ---
# TRITA_API_PORT=8000
# TRITA_RUN_ISOLATION=1
# TRITA_RUN_VA05=1
# TRITA_RUN_VA09=1
# TRITA_ORCH_INGEST_MODE=direct

# --- Email / Slack (Phase 3+) ---
RESEND_API_KEY=
SLACK_WEBHOOK_URL=

# --- Billing (Phase 5) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
